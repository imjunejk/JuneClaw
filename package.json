{
  "name": "juneclaw",
  "version": "0.1.0",
  "description": "Personal AI assistant daemon — Claude CLI gateway over iMessage",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "private": true,
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "node-cron": "^4.2.1",
    "zod": "^4.3.6"
  }
}
